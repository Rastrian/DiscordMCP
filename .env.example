# Discord MCP Platform — Environment Variables

# App
APP_NAME=discord-mcp-platform
DEBUG=false
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/discord_mcp_platform
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://redis:6379/0

# Discord OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8000/auth/discord/callback

# Discord Bot
DISCORD_BOT_TOKEN=

# Security
SECRET_KEY=change-me-in-production
ALLOWED_GUILD_IDS=[]
ALLOWED_CHANNEL_IDS=[]

# MCP
MCP_TRANSPORT=http

# Gateway
ENABLE_GATEWAY=true

# Agent (Conversational AI)
AGENT_ENABLED=false
AGENT_API_BASE_URL=https://api.z.ai/api/anthropic
AGENT_API_KEY=
AGENT_MODEL=glm-4.5
AGENT_MAX_HISTORY=20
AGENT_COOLDOWN_SECONDS=5
